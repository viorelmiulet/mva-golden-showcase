{
  "manifest_version": 3,
  "name": "MVA Admin Panel",
  "version": "2.0.0",
  "description": "Notificări push pentru emailuri noi și vizionări programate — MVA Imobiliare",
  "permissions": [
    "notifications",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://fdpandnzblzvamhsoukt.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MVA Admin Panel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
